# dependencies
node_modules/

# build artifacts
dist/
web/dist/
server/dist/
*.tsbuildinfo
# Exception: the Lovelace card under lovelace/dist/ is the SOURCE (no build
# step — it's a self-contained Web Component) and MUST be committed so HACS
# can serve it directly from the repo.
!lovelace/dist/
!lovelace/dist/**

# env / secrets — never commit
.env
.env.local
.env.production

# logs
*.log

# OS / editor
.DS_Store
.vscode/
.idea/

# local data (SQLite recorder + per-run scratch)
data/
tmp/
.tmp/

# Claude session/scratch (kept local)
.claude/
