<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tesseractAZ.ecoflow-panel</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/npm</string>
        <string>start</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/tesseractAZ/Downloads/Claude/ecoflow-panel/server</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/tesseractAZ/Downloads/Claude/ecoflow-panel/data/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/tesseractAZ/Downloads/Claude/ecoflow-panel/data/launchd.err.log</string>
</dict>
</plist>
