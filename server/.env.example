# EcoFlow IoT Open API credentials — generate at https://developer-eu.ecoflow.com/
ECOFLOW_ACCESS_KEY=your_access_key_here
ECOFLOW_SECRET_KEY=your_secret_key_here

# Regional API host. Try api-a.ecoflow.com first; some accounts route to api-e (EU) or api-us (US).
ECOFLOW_API_HOST=https://api-a.ecoflow.com

# Server config
PORT=8787
HOST=127.0.0.1

# SQLite path (relative to server/ dir)
DB_PATH=../data/ecoflow.db

# Logging
LOG_LEVEL=info

# --- Push notifications ---
# Channel: none | ntfy | pushover | webhook
NOTIFY_CHANNEL=none
# Minimum severity to push: warning (warning+critical) | critical
NOTIFY_MIN_SEVERITY=warning
# Also notify when a condition clears (1/0)
NOTIFY_RESOLVED=1
# ntfy — free, no account. Pick a long random topic and keep it private.
NOTIFY_NTFY_SERVER=https://ntfy.sh
NOTIFY_NTFY_TOPIC=ecoflow-panel-CHANGE-ME
# Pushover (optional)
NOTIFY_PUSHOVER_TOKEN=
NOTIFY_PUSHOVER_USER=
# Generic JSON webhook (optional)
NOTIFY_WEBHOOK_URL=
